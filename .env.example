# ---- Database ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0

# ---- Auth (NextAuth) ----
# Generate a secret: `openssl rand -hex 32`
NEXTAUTH_SECRET=replace-with-random-32-byte-hex
NEXTAUTH_URL=http://localhost:3000

# Public origin for sitemap.xml, robots.txt and metadata canonical/OG URLs.
# Set to the real production domain on deploy (e.g. https://sugamclinic.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Admin bootstrap account ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ---- ImageKit (media CDN) ----
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# ---- Email (SMTP, e.g. Gmail app password) ----
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=app-password
EMAIL_FROM=your@gmail.com

# ---- Upstash Redis (rate limiting) ----
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
